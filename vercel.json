{
  "version": 2,
  "builds": [
    { "src": "server.js", "use": "@vercel/node" },
    { "src": "public/**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/extract-dates", "dest": "/server.js" },
    { "src": "/create-when2meet", "dest": "/server.js" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
